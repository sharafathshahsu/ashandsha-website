<%- include('partials/head', { title, description, path, SITE_URL }) %>
<%- include('partials/header', { active }) %>

<section class="page-hero">
  <div class="container" data-aos="fade-up">
    <span class="eyebrow">Contact</span>
    <h1>We'd love to hear from you</h1>
    <p class="lead">Questions, custom orders, wholesale inquiries — send us a message and we'll get back to you within 1-2 business days.</p>
  </div>
</section>

<section class="section section-tight">
  <div class="container split">
    <div class="split-copy" data-aos="fade-up">
      <% if (typeof submitted !== 'undefined' && submitted) { %>
        <div class="alert-success">
          <strong>Thanks for reaching out!</strong> We'll get back to you soon.
        </div>
      <% } %>
      <form class="contact-form" action="/contact" method="POST">
        <div class="form-row">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="form-row">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-row">
          <label for="topic">What's this about?</label>
          <select id="topic" name="topic">
            <option>General question</option>
            <option>Order status</option>
            <option>Custom design</option>
            <option>Wholesale inquiry</option>
          </select>
        </div>
        <div class="form-row">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
      </form>
    </div>
    <div class="split-visual contact-info" data-aos="fade-up" data-aos-delay="120">
      <h3>Other ways to reach us</h3>
      <p><strong>Email</strong><br><a href="mailto:hello@ashandsha.com">hello@ashandsha.com</a></p>
      <p><strong>Location</strong><br>Fort McMurray, Alberta, Canada</p>
      <p><strong>Response time</strong><br>Usually within 1-2 business days</p>
      <p><strong>Follow along</strong><br>Instagram, Facebook &amp; TikTok — links in the footer.</p>
    </div>
  </div>
</section>

<%- include('partials/footer', { year }) %>
