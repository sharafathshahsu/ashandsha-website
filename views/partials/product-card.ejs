<a href="/product/<%= p.id %>" class="product-card" data-aos="fade-up">
<div class="product-thumb">
<% if (p.compare_at) { %><span class="badge badge-sale">Sale</span><% } %>
<img src="/assets/<%= p.image %>" alt="<%= p.name %>" loading="lazy">
<button type="button" class="card-add-btn add-to-cart" aria-label="Add to cart" title="Add to cart" data-id="<%= p.id %>" data-name="<%= p.name %>" data-price="<%= p.price %>" data-image="/assets/<%= p.image %>">+</button>
<span class="product-quickview">View Product →</span>
</div>
<div class="product-info">
<span class="product-cat"><%= p.category %></span>
<h3><%= p.name %></h3>
<div class="product-price">
<span class="price-now">$<%= p.price.toFixed(2) %></span>
<% if (p.compare_at) { %><span class="price-was">$<%= p.compare_at.toFixed(2) %></span><% } %>
</div>
</div>
</a>
