<%- include('partials/head', { title, description, path, SITE_URL }) %>
<%- include('partials/header', { active }) %>

<section class="page-hero">
  <div class="container" data-aos="fade-up">
    <span class="eyebrow">Custom Orders</span>
    <h1>Got a model? Get a price.</h1>
    <p class="lead">Upload an STL, OBJ, or 3MF file and we'll preview it, then instantly estimate the size, weight, print time, and price for a one-off 3D print — made to order in Fort McMurray, Alberta.</p>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="upload-tool" data-aos="fade-up">

      <form id="stl-form" class="upload-form">
        <label for="stl-input" class="upload-dropzone" id="dropzone">
          <input type="file" id="stl-input" name="stl" accept=".stl,.obj,.3mf" hidden>
          <div class="upload-dropzone-icon">📐</div>
          <p class="upload-dropzone-title">Drag &amp; drop your .STL, .OBJ, or .3MF file here</p>
          <p class="upload-dropzone-sub">or click to browse — max 50MB · max build size 256 × 256 × 256 mm</p>
          <p class="upload-dropzone-file" id="file-name"></p>
        </label>

        <div class="model-preview" id="model-preview">
          <p class="model-preview-empty" id="preview-empty">Your 3D preview will appear here</p>
          <canvas id="preview-canvas" hidden></canvas>
        </div>

        <div class="form-row upload-infill-row">
          <label for="infill">Infill density</label>
          <select id="infill" name="infill">
            <option value="10">10% — lightweight, decorative</option>
            <option value="20" selected>20% — standard, everyday use</option>
            <option value="30">30% — sturdier, functional parts</option>
            <option value="50">50% — heavy-duty</option>
            <option value="100">100% — solid</option>
          </select>
        </div>

        <div class="form-row upload-material-row">
          <label for="material">Material</label>
          <select id="material" name="material">
            <% Object.entries(materials || { PLA: { label: 'PLA' }, PETG: { label: 'PETG' } }).forEach(([key, m]) => { %>
              <option value="<%= key %>" <%= key === 'PLA' ? 'selected' : '' %>><%= m.label %><%= key === 'PLA' ? ' — most affordable, great all-rounder' : ' — tougher, heat &amp; impact resistant' %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-row upload-multicolor-row">
          <label class="checkbox-label">
            <input type="checkbox" id="multicolor-toggle" name="multicolor">
            Multicolour print (up to 4 filament colours)
          </label>
          <select id="color-count" disabled>
            <option value="2">2 colours</option>
            <option value="3">3 colours</option>
            <option value="4">4 colours</option>
          </select>
        </div>

        <div class="color-swatch-row" id="color-swatch-row" hidden>
          <label class="color-swatch"><span>Colour 1</span><input type="color" value="#ff5a36"></label>
          <label class="color-swatch"><span>Colour 2</span><input type="color" value="#1a1a2e"></label>
          <label class="color-swatch"><span>Colour 3</span><input type="color" value="#ffffff"></label>
          <label class="color-swatch"><span>Colour 4</span><input type="color" value="#00bfa6"></label>
        </div>

        <p class="upload-size-warning" id="size-warning" hidden></p>

        <button type="submit" class="btn btn-primary btn-lg" id="estimate-btn" disabled>Get Instant Estimate</button>
        <p class="upload-error" id="upload-error" hidden></p>
      </form>

      <div class="estimate-result" id="estimate-result" hidden data-aos="fade-up">
        <h3>Your estimate</h3>
        <p class="estimate-filename" id="estimate-filename"></p>

        <div class="estimate-grid">
          <div class="estimate-stat">
            <span class="estimate-stat-label">Dimensions</span>
            <span class="estimate-stat-value" id="stat-dimensions">—</span>
          </div>
          <div class="estimate-stat">
            <span class="estimate-stat-label">Volume</span>
            <span class="estimate-stat-value" id="stat-volume">—</span>
          </div>
          <div class="estimate-stat">
            <span class="estimate-stat-label">Est. weight</span>
            <span class="estimate-stat-value" id="stat-weight">—</span>
          </div>
          <div class="estimate-stat">
            <span class="estimate-stat-label">Est. print time</span>
            <span class="estimate-stat-value" id="stat-time">—</span>
          </div>
          <div class="estimate-stat">
            <span class="estimate-stat-label">Material</span>
            <span class="estimate-stat-value" id="stat-material">—</span>
          </div>
        </div>

        <div class="estimate-price">
          <div>
            <span class="estimate-price-label">Estimated price (CAD)</span>
            <span class="estimate-price-value" id="stat-price">—</span>
          </div>
          <ul class="estimate-breakdown" id="estimate-breakdown"></ul>
        </div>

        <p class="micro-note">This is a ballpark estimate based on your model's volume at <span id="stat-infill"></span> infill. Final pricing may vary based on supports, finish, and material choice — we'll confirm everything before printing.</p>

        <a href="/contact" id="request-quote-btn" class="btn btn-primary btn-lg">Request This Quote</a>
      </div>

    </div>
  </div>
</section>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module" src="/js/model-viewer.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    var canvas = document.getElementById('preview-canvas');
    if (canvas && window.customElements) {
      // Poll briefly for the module script to attach window.ModelViewer.
      var tries = 0;
      (function tryInit() {
        if (window.ModelViewer) {
          window.ModelViewer.init(canvas);
        } else if (tries++ < 50) {
          setTimeout(tryInit, 100);
        }
      })();
    }
  });
</script>

<section class="section section-alt">
  <div class="container">
    <div class="section-head center" data-aos="fade-up">
      <span class="eyebrow">How it works</span>
      <h2>From file to finished print</h2>
      <p class="section-sub">Three steps to get your custom part made.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card" data-aos="fade-up">
        <span class="step-num">01</span>
        <h3>Upload your model</h3>
        <p>Export an STL, OBJ, or 3MF from your CAD or 3D scanning software and drop it above for an instant preview, size &amp; price estimate.</p>
      </div>
      <div class="step-card" data-aos="fade-up" data-aos-delay="80">
        <span class="step-num">02</span>
        <h3>Request your quote</h3>
        <p>Send us the estimate along with any notes — colour, material, quantity — and we'll confirm the final details.</p>
      </div>
      <div class="step-card" data-aos="fade-up" data-aos-delay="160">
        <span class="step-num">03</span>
        <h3>We print &amp; ship</h3>
        <p>Your part is printed to order in Fort McMurray, Alberta and shipped Canada-wide.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { year }) %>
